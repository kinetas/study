          </mxGeometry>
        </mxCell>
        <mxCell id="TxAdA2J8B9WnWhSmdfe_-15" parent="TxAdA2J8B9WnWhSmdfe_-13" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;align=left;spacingLeft=6;fontStyle=0;overflow=hidden;whiteSpace=wrap;html=1;fontSize=12;labelBackgroundColor=none;fontColor=default;" value="&lt;div style=&quot;text-wrap: nowrap;&quot;&gt;&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; line-height: 19px; white-space-collapse: preserve;&quot;&gt;&lt;div&gt;&lt;span&gt;1.&lt;/span&gt; 회원은 아이디 또는 전화번호를 입력한다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;2.&lt;/span&gt; 회원은 비밀번호를 입력한다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;3.&lt;/span&gt; 회원은 로그인 버튼을 클릭한다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;4.&lt;/span&gt; &lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;클라이언트는 입력값 유효성을 검증한다.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;5.&lt;/span&gt; 클라이언트는 시스템에 로그인 요청을 보낸다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;6.&lt;/span&gt; 시스템은 회원 정보와 비밀번호 일치 여부를 검증한다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;7.&lt;/span&gt; 시스템은 access token과 refresh token을 생성한다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;8.&lt;/span&gt; 시스템은 브라우저 쿠키에 refresh token을 반환하고, 클라이언트에게 토큰을 반환한다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;9.&lt;/span&gt; 클라이언트는 access token을 저장하고 메인페이지로 이동한다.&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="182" width="610" x="60" as="geometry">
            <mxRectangle height="182" width="610" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="TxAdA2J8B9WnWhSmdfe_-16" parent="TxAdA2J8B9WnWhSmdfe_-0" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;fillColor=none;collapsible=0;dropTarget=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;top=0;left=0;right=0;bottom=1;fontSize=12;labelBackgroundColor=none;fontColor=default;" value="" vertex="1">
