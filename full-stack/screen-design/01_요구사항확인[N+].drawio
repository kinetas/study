        <mxCell id="TxAdA2J8B9WnWhSmdfe_-18" parent="TxAdA2J8B9WnWhSmdfe_-16" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;align=left;spacingLeft=6;fontStyle=0;overflow=hidden;whiteSpace=wrap;html=1;fontSize=12;labelBackgroundColor=none;fontColor=default;" value="&lt;div style=&quot;font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; line-height: 19px; white-space: pre;&quot;&gt;&lt;div&gt;&lt;div&gt;A 자동 로그인&lt;/div&gt;&lt;div&gt;1. 시스템은 저장된 refresh token 존재 여부를 확인한다.&lt;/div&gt;&lt;div&gt;2. refresh token이 유효하면 access token을 재발급한다.&lt;/div&gt;&lt;div&gt;3. 클라이언트는 메인페이지로 이동한다.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;B 아이디 찾기&lt;/div&gt;&lt;div&gt;1. 회원은 아이디 찾기를 선택한다.&lt;/div&gt;&lt;div&gt;2. 시스템은 아이디 찾기 페이지로 이동한다.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;C 비밀번호 찾기&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;1.&lt;/span&gt; 회원은 비밀번호 찾기를 선택한다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;2.&lt;/span&gt; 시스템은 비밀번호 찾기 페이지로 이동한다.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;D 회원가입&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;1.&lt;/span&gt; 회원은 회원가입을 선택한다.&lt;/div&gt;&lt;div&gt;&lt;span&gt;2.&lt;/span&gt; 시스템은 회원가입 페이지로 이동한다.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="610" x="60" as="geometry">
            <mxRectangle height="290" width="610" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="TxAdA2J8B9WnWhSmdfe_-19" parent="TxAdA2J8B9WnWhSmdfe_-0" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;fillColor=none;collapsible=0;dropTarget=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;top=0;left=0;right=0;bottom=1;fontSize=12;labelBackgroundColor=none;fontColor=default;" value="" vertex="1">
