        <mxCell id="TxAdA2J8B9WnWhSmdfe_-14" parent="TxAdA2J8B9WnWhSmdfe_-13" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;fontStyle=1;overflow=hidden;whiteSpace=wrap;html=1;fontSize=12;labelBackgroundColor=none;fontColor=default;" value="기본흐름" vertex="1">
          <mxGeometry height="182" width="60" as="geometry">
