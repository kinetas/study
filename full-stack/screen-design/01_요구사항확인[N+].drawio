        </mxCell>
        <mxCell id="TxAdA2J8B9WnWhSmdfe_-17" parent="TxAdA2J8B9WnWhSmdfe_-16" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;fontStyle=1;overflow=hidden;whiteSpace=wrap;html=1;fontSize=12;labelBackgroundColor=none;fontColor=default;" value="대안흐름" vertex="1">
